{
  "name": "claude-tutorial2",
  "version": "1.0.0",
  "description": "Hono + AWS Lambda tutorial",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/local.ts",
    "build": "esbuild src/lambda.ts --bundle --platform=node --target=node20 --outfile=dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@hono/node-server": "^1.13.7",
    "@types/aws-lambda": "^8.10.146",
    "@types/node": "^22.10.2",
    "esbuild": "^0.24.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
